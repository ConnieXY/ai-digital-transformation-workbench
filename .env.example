# ===== Supabase（服务端使用 service_role，绝不暴露前端）=====
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret   # Supabase → Settings → API → service_role
# 可选：客户端如需直连（当前架构不需要）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===== LLM（OpenAI 兼容；切平台只改这三项，无需改代码）=====
# OpenAI:   LLM_BASE_URL=https://api.openai.com/v1          LLM_MODEL=gpt-4o-mini
# DeepSeek: LLM_BASE_URL=https://api.deepseek.com           LLM_MODEL=deepseek-chat
# 通义千问:  LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   LLM_MODEL=qwen-plus
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-llm-api-key

# ===== Embedding（RAG / P0-3 使用；需 1536 维模型）=====
# OpenAI:  EMBEDDING_BASE_URL=https://api.openai.com/v1     EMBEDDING_MODEL=text-embedding-3-small
# 百炼:    EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=your-embedding-api-key

# ===== RAG 相关性门控（低于该余弦相似度的片段不喂给 LLM，促使弱语料时诚实弃权）=====
RAG_MIN_SIMILARITY=0.48

# ===== 滥用 / 成本防护 =====
# 公网真实 AI 总开关：false 时即使配置了 LLM key，也只走规则降级 / featured 快照；true 才允许真跑
PUBLIC_AI_ENABLED=false
# 每个匿名主体每日 credits（匿名 JWT 的 sub，回退 IP）；默认 15
PUBLIC_AI_DAILY_CREDITS=15
# 每分钟每主体（匿名 JWT 的 sub，回退 IP）请求上限，超出返回 429
RATE_LIMIT_PER_MIN=60
# 当日 LLM + Embedding 成本上限（美元）；达到后自动降级为规则路径，不再调用付费模型。≤0 表示不设限
LLM_DAILY_COST_CAP_USD=1

# ===== 评测裁判（建议用不同于生成器的模型做跨模型评判；缺省回退 embedding 凭据 + qwen-plus）=====
# JUDGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# JUDGE_MODEL=qwen-plus
# JUDGE_API_KEY=your-judge-key
